  <entry>
    <title>Javascript 模块化编程-require.js 的用法</title>
    <link href="http://guoxb.com/2017/08/28/JavaScript%E6%A8%A1%E5%9D%97%E5%8C%96%E7%BC%96%E7%A8%8B%EF%BC%9Arequire.js%E7%9A%84%E7%94%A8%E6%B3%95/"/>
